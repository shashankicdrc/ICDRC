NODE_ENV=development
PORT=7000

MONGO_URL=mongodb://localhost:27017/icdrc
JWT_SECRET=your_jwt_secret_here

GOOGLE_CLIENT_ID=your_google_client_id

CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret
MAIL_PASSWORD=your_mail_password

MERCHANT_ID=your_phonepe_merchant_id
SALT_INDEX=1
SALT_KEY=your_phonepe_salt_key
# PG v2 OAuth (required for /oauth/token — use values from Dashboard → Developer Settings).
# 401 errors usually mean wrong env or using SALT_KEY instead of the OAuth Client Secret.
# PHONEPE_CLIENT_ID=
# PHONEPE_CLIENT_SECRET=
# PHONEPE_CLIENT_VERSION=
# PhonePe hosts: sandbox when NODE_ENV is not production. Set PHONEPE_ENV=production if your
# credentials are live while developing locally; use PHONEPE_ENV=sandbox for UAT on prod servers.
# PHONEPE_ENV=production

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:7000

REDIS_HOST=redis
REDIS_PORT=6379
