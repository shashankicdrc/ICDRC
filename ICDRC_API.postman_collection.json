              "mode": "raw",
              "raw": "{\n  \"id\": \"COMPLAINT_ID_HERE\",\n  \"complaintType\": \"IndividualComplaint\",\n  \"amount\": 500,\n  \"userId\": \"USER_ID_HERE\"\n}"
            }
          }
        }
