{
  "info": {
    "_postman_id": "icdrc-api-collection",
    "name": "ICDRC API",
    "description": "Complete API collection for ICDRC dev server (https://dev-api.icdrc.in)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://dev-api.icdrc.in",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "Set this after signing in"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"provider\": \"credential\"\n}"
            }
          }
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.AccessToken) {",
                  "  pm.collectionVariables.set('access_token', res.data.AccessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/auth/signin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/token/rotation?refreshtoken=REPLACE_WITH_REFRESH_TOKEN",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "token", "rotation"],
              "query": [{"key": "refreshtoken", "value": "REPLACE_WITH_REFRESH_TOKEN"}]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/auth/change/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"OldPassword@123\",\n  \"newPassword\": \"NewPassword@123\"\n}"
            }
          }
        },
        {
          "name": "Reset Password Request",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/auth/reset/password/request",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/auth/reset/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"code\": \"123456\",\n  \"password\": \"NewPassword@123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Individual Complaints",
      "item": [
        {
          "name": "Register Individual Complaint",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/individual/complaints",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"mobile\": \"+919876543210\",\n  \"email\": \"john@example.com\",\n  \"state\": \"Maharashtra\",\n  \"city\": \"Mumbai\",\n  \"address\": \"123, Main St\",\n  \"policyCompany\": \"Bajaj Allianz General Insurance Company Limited\",\n  \"policyType\": \"Health Insurance\",\n  \"problem\": \"Fraud\",\n  \"problemDetails\": \"Detailed description of the problem\",\n  \"isSubscribed\": false,\n  \"subscriptionId\": null\n}"
            }
          }
        },
        {
          "name": "Get My Individual Complaints",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/individual/complaints"
          }
        },
        {
          "name": "Get Individual Complaint by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/individual/complaints/COMPLAINT_ID_HERE"
          }
        },
        {
          "name": "Get My Individual Complaint Count",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/individual/complaints/count"
          }
        },
        {
          "name": "[Admin] Get All Individual Complaints",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/admin/individual/complaints?page=1&perRow=20",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "individual", "complaints"],
              "query": [{"key": "page", "value": "1"}, {"key": "perRow", "value": "20"}]
            }
          }
        },
        {
          "name": "[Admin] Update Individual Case Status",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/admin/individual/complaints",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"COMPLAINT_ID_HERE\",\n  \"status\": \"Resolved\"\n}"
            }
          }
        },
        {
          "name": "[Admin] Delete Individual Complaints",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/admin/individual/complaints",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"individualIds\": [\"ID_1\", \"ID_2\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Organisational Complaints",
