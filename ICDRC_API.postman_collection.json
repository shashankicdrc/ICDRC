        },
        {
          "name": "Get My Organisational Complaint Count",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/organisational/complaints/count"
          }
        },
        {
          "name": "[Admin] Get All Organisational Complaints",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/admin/organisational/complaints?page=1&perRow=20",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "organisational", "complaints"],
              "query": [{"key": "page", "value": "1"}, {"key": "perRow", "value": "20"}]
            }
          }
        },
        {
          "name": "[Admin] Delete Organisational Complaints",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/admin/organisational/complaints",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organisationalIds\": [\"ID_1\", \"ID_2\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Get My Subscription",
          "request": {
            "method": "GET",
